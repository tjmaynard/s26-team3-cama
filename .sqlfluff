# SQLFluff configuration file
#
# Customize this file in consultation with the rest of your team to ensure
# that you have a consistent SQL style. See the SQLFluff documentation for
# more information: https://docs.sqlfluff.com/en/stable/configuration/

[sqlfluff]
dialect = bigquery
rules = core
exclude_rules = LT05,AL07,ST07,RF06
templater = placeholder

[sqlfluff:templater:placeholder]
param_style = dollar

[sqlfluff:templater:placeholder:context]
project_id = musa5090s26-teamX
dataset_name = source
bucket_name = musa5090s26-teamX-prepared_data

[sqlfluff:indentation]
indent_unit = space
tab_space_size = 4

[sqlfluff:rules:capitalisation.keywords]
capitalisation_policy = upper

[sqlfluff:rules:capitalisation.identifiers]
capitalisation_policy = lower

[sqlfluff:rules:capitalisation.functions]
capitalisation_policy = upper

[sqlfluff:rules:capitalisation.literals]
capitalisation_policy = upper

[sqlfluff:rules:capitalisation.types]
capitalisation_policy = upper
